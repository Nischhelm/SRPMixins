{
  "required": true,
  "package": "srpmixins.mixin.features.commandfix",
  "refmap": "mixins.srpmixins.refmap.json",
  "compatibilityLevel": "JAVA_8",
  "target": "@env(DEFAULT)",
  "minVersion": "0.8",
  "mixins": [
    "SRPCommandEvolutionMixin",
    "SRPCommandColonyMixin",
    "SRPCommandNodeMixin",
    "SRPCommandRootMixin"
